# Copy to .env.local and fill in. Only needed for PARTNER (multi-user) mode.
# Personal mode (the default) needs none of this.

# VITE_SNAPTRADE_MODE=partner

# Supabase frontend (publishable/anon key — safe in the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase backend (service role — server only, never expose)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SnapTrade partner keys (server only) — Pay-as-you-go, NOT Personal keys
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
